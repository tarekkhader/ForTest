PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/ecommerce
# Max JSON body size (product images as base64 need more than default 100kb)
JSON_BODY_LIMIT=50mb
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d
# Primary dashboard admin username (default omargamal404)
DASHBOARD_ADMIN_USERNAME=omargamal404
# Optional: more admin logins without touching the database (comma-separated)
# DASHBOARD_ADMIN_USERNAMES=alice,bob
# Optional: create that user on startup if missing (password defaults to 2112)
SEED_DASHBOARD_ADMIN=false
DASHBOARD_ADMIN_PASSWORD=2112
DASHBOARD_ADMIN_EMAIL=omargamal404@dashboard.local
